{
  "name": "reference-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "test:ci": "vitest run --config vite.config.ts --coverage",
    "lint": "eslint . --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern packages/types/src/index.ts --ignore-pattern \".cache\" --ignore-pattern public",
    "lint:fix": "pnpm lint --fix",
    "preview": "vite preview",
    "format": "prettier --write \"**/*\"",
    "format:fix": "prettier --write \"**/*\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vite.config.ts",
    "test:watch": "vitest watch --config vite.config.ts"
  },
  "packageManager": "pnpm@9.1.0",
  "dependencies": {
    "@code-hike/mdx": "0.9.0",
    "@marigold/components": "9.0.2",
    "@marigold/icons": "1.2.57",
    "@marigold/system": "^9.0.2",
    "@marigold/theme-core": "26.2.1",
    "@marigold/theme-docs": "^2.1.1",
    "@mdx-js/rollup": "3.1.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tanstack/react-query": "5.59.15",
    "@tanstack/react-query-devtools": "5.59.15",
    "@tanstack/react-router": "1.74.4",
    "@vercel/analytics": "^1.3.1",
    "codehike": "^1.0.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@marigold/eslint-config": "0.4.16",
    "@marigold/prettier-config": "0.3.1",
    "@tanstack/router-devtools": "1.74.4",
    "@tanstack/router-vite-plugin": "1.74.2",
    "@testing-library/jest-dom": "6.6.2",
    "@testing-library/react": "16.0.1",
    "@types/jest": "29.5.13",
    "@types/node": "22.7.7",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "@types/react-test-renderer": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.10.0",
    "@typescript-eslint/parser": "8.10.0",
    "@vitejs/plugin-react-swc": "3.7.1",
    "@vitest/coverage-v8": "2.1.3",
    "autoprefixer": "10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.13",
    "eslint-plugin-tailwindcss": "3.17.5",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "react-test-renderer": "18.3.1",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "5.4.9",
    "vitest": "2.1.3"
  }
}
